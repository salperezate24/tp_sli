{
  "name": "sustentacion-tesis-ovocitos-slidev",
  "description": "Diapositivas de sustentacion de tesis de maestria sobre deteccion de ovocitos y caracteristicas morfologicas en microscopia polarizada.",
  "type": "module",
  "private": true,
  "author": "Salomon Perez Atencia",
  "contributors": [
    "Alejandro Restrepo Martinez (Director de tesis)"
  ],
  "thesisMetadata": {
    "author": "Salomon Perez Atencia",
    "advisor": "Alejandro Restrepo Martinez, Ph. D.",
    "program": "Maestria",
    "institution": "Universidad Nacional de Colombia, Sede Medellin",
    "faculty": "Facultad de Minas",
    "department": "Departamento de Ciencias de la Computacion"
  },
  "keywords": [
    "slidev",
    "tesis",
    "sustentacion",
